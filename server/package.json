    "nodemailer": "^8.0.5",
    "openai": "^6.34.0",
    "shared": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/nodemailer": "^8.0.0",
    "drizzle-kit": "^0.31.10"
